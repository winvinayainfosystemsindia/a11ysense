# A11ySense AI - QA Environment
APP_NAME="A11ySense AI"
APP_ENV=qa
LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here

# Database Configuration
POSTGRES_SERVER=localhost
POSTGRES_USER=winvinaya_user
POSTGRES_PASSWORD=winvinaya12345
POSTGRES_DB=a11ysense_qa
POSTGRES_PORT=5432

# Ports
GATEWAY_PORT=8100
AGENT_PORT=8101
REPORTING_PORT=8102

# Service Discovery
AGENT_SERVICE_URL=http://localhost:8101
REPORTING_SERVICE_URL=http://localhost:8102

# Reporting
ALLURE_RESULTS_DIR=/app/storage/reports/allure-results/qa

# JWT Authentication
SECRET_KEY=qwertyuiopasdfghjklzxcvbnm1234567890
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# CORS Origins (comma-separated)
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:5173,https://qa-a11ysense.winvinaya.com

# Rate Limiting
RATE_LIMIT_ENABLED=False
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=10000

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_ROTATION=500 MB
LOG_RETENTION=30 days
LOG_FORMAT=json

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Email Configuration (optional - for future use)
SMTP_TLS=True
SMTP_PORT=587
SMTP_HOST=s.mail25.info
SMTP_USER=no-reply@winvinaya.com
SMTP_PASSWORD=Admin##2025@
EMAILS_FROM_EMAIL=no-reply@winvinaya.com
EMAILS_FROM_NAME=winvinaya
FRONTEND_URL=https://qa-a11ysense.winvinaya.com
