# LLM Configuration
LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here

APP_NAME="A11ySense AI"
APP_VERSION=1.0.0
API_V1_PREFIX=/api/v1
DEBUG=True
ENVIRONMENT=development

# Server Configuration
HOST=0.0.0.0
PORT=8000
WORKERS=4

# Database Configuration
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=12345
POSTGRES_DB=a11ysense
POSTGRES_PORT=5432

SECRET_KEY=qwertyuiopasdfghjklzxcvbnm1234567890
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# CORS Origins (comma-separated)
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Rate Limiting
RATE_LIMIT_ENABLED=False
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=10000

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_ROTATION=500 MB
LOG_RETENTION=30 days
LOG_FORMAT=json

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Email Configuration (optional - for future use)
SMTP_TLS=True
SMTP_PORT=587
SMTP_HOST=s.mail25.info
SMTP_USER=no-reply@winvinaya.com
SMTP_PASSWORD=Admin##2025@
EMAILS_FROM_EMAIL=no-reply@winvinaya.com
EMAILS_FROM_NAME=winvinaya
FRONTEND_URL=http://localhost:5173